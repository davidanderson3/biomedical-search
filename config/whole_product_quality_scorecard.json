{
  "version": 1,
  "name": "Whole Product Quality Scorecard",
  "description": "Weighted product-level estimate built from current search-quality lanes. This is intentionally broader than any single run's overall_score.",
  "weights_note": "Weights sum to 100. The weak-note and PubMed lanes carry high weight because dependable search requires realistic clinical text and long-document behavior, not only short curated checks.",
  "category_policy": "Keep exactly eight user-facing product categories. Add new measurements inside the existing lanes instead of adding new top-level cards or score lanes.",
  "measurement_dimensions": [
    "First-page recall and row completeness at top 10/top 20/top 60.",
    "Near-miss severity: recovered just below the first page versus absent from the candidate window.",
    "First-answer trust: top-on-target and wrong-first rows.",
    "Precision and page cleanliness: configured disallowed concepts, clean-page checks, and reviewed false-positive samples.",
    "Role and context accuracy: active/current versus history, diagnosis versus symptom/test, and medication role where reviewed.",
    "Coverage stratification by text style, semantic group, and public source.",
    "Stability and churn across rotating smoke runs and candidate lane expansions.",
    "Operational signals such as latency, cache behavior, and source/result collapse when available."
  ],
