{
  "chunk_id": "pubmed_bulk_recent_1321_1320",
  "title": "PubMed bulk recent shards 1321 and 1320",
  "max_minutes_per_step": 10,
  "scope": "Eighth bounded PubMed bulk ingest pilot. Adds high-numbered 2026 baseline files pubmed26n1321 and pubmed26n1320 after the ingested pubmed26n1323/pubmed26n1322 batch.",
  "steps": [
    {
      "id": "download_recent_1321_1320",
      "label": "Download PubMed 2026 baseline shards 1321 and 1320",
      "artifacts": [
        {
          "path": "data/pubmed/baseline/pubmed26n1321.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1321.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1320.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1320.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "build/pubmed_bulk_recent_1321_1320_manifest.json",
          "kind": "file"
        }
      ]
    },
    {
      "id": "parse_recent_1321_1320",
      "label": "Stream-parse shards 1321 and 1320 into corpus JSONL",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1321_1320_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "link_profiles",
      "label": "Link shards 1321 and 1320 through UMLS profile shards",
      "artifacts": [
        {
          "glob": "build/profile_evidence_pubmed_bulk_recent_1321_1320/*.jsonl",
          "kind": "jsonl",
          "min_files": 7,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "build_docs",
      "label": "Aggregate shards 1321 and 1320 evidence into CUI/view documents",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1321_1320_concept_documents.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/pubmed_bulk_recent_1321_1320_docs.sqlite",
          "kind": "file"
        }
      ]
    },
    {
      "id": "embed_vectors",
      "label": "Embed shards 1321 and 1320 CUI/view documents with SapBERT CLS vectors",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1321_1320_concept_vectors.sapbert_cls.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "export_elastic",
      "label": "Export shards 1321 and 1320 vectors for Elasticsearch",
      "artifacts": [
        {
          "path": "build/qe-scaling-pubmed-bulk-recent-1321-1320-sapbert-cls.elastic.mapping.json",
          "kind": "file"
        },
        {
          "glob": "build/qe-scaling-pubmed-bulk-recent-1321-1320-sapbert-cls.elastic.bulk.part-*.ndjson",
          "kind": "file",
          "min_files": 1
        }
      ]
    },
    {
      "id": "load_elastic",
      "label": "Load shards 1321 and 1320 vectors into Elasticsearch",
      "artifacts": [
        {
          "path": "build/scaling_runs/elasticsearch_loaded_pubmed_bulk_recent_1321_1320_sapbert_cls.marker",
          "kind": "file"
        }
      ]
    },
    {
      "id": "quality_review",
      "label": "Review shards 1321 and 1320 search quality before wider bulk ingest",
      "artifacts": [
        {
          "path": "build/scaling_runs/pubmed_bulk_recent_1321_1320/search_quality_judgments.csv",
          "kind": "file"
        }
      ]
    }
  ]
}
