          "kind": "jsonl",
          "min_files": 7,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "current_concept_documents",
      "label": "Build current baseline CUI/view concept documents",
      "artifacts": [
        {
          "path": "build/scaling_chunk_002_common_clinical_concept_documents.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "chunk_001_sapbert_vectors",
