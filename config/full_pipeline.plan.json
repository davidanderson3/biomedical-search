{
  "chunk_id": "full_pipeline",
  "title": "Full biomedical search pipeline",
  "scope": "End-to-end readiness view. This is not percent coverage of all biomedicine; it tracks pipeline stages and major missing pieces.",
  "max_minutes_per_step": null,
  "steps": [
    {
      "id": "umls_profile_indexes",
      "label": "Build UMLS semantic profile, search label, and CUI/code resolver indexes",
      "why": "Builds the identity layer that lets user strings, CUIs, and source vocabulary codes resolve before semantic search.",
      "artifacts": [
        {
          "glob": "build/profile_indexes/*.sqlite",
          "kind": "file",
          "min_files": 7
        },
        {
          "path": "build/umls_biomedicine_search_label_index.sqlite",
          "kind": "sqlite",
          "count_table": "labels",
          "min_rows": 1
        },
        {
          "path": "build/cui_code_index.sqlite",
          "kind": "sqlite",
          "count_table": "code_mappings",
          "min_rows": 1
        },
        {
          "path": "build/umls_semantic_types.sqlite",
          "kind": "sqlite",
          "count_table": "semantic_types",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "expanded_literature_corpora",
      "label": "Harvest expanded PubMed and Europe PMC topic corpora",
      "artifacts": [
        {
          "path": "build/pubmed_biomedicine_expanded_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/europepmc_biomedicine_expanded_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
