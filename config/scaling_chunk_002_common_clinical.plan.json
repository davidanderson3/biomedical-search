{
  "chunk_id": "scaling_chunk_002_common_clinical",
  "title": "Chunk 002: common clinical language",
  "max_minutes_per_step": 10,
  "scope": "PubMed abstracts, Europe PMC abstracts, PMC Open Access full text, and a bounded local MIMIC-IV-Note pilot from the credentialed Downloads copy.",
  "steps": [
    {
      "id": "fetch_literature",
      "label": "Fetch PubMed, Europe PMC, and PMC OA topic corpora",
      "artifacts": [
        {
          "path": "build/pubmed_scaling_chunk_002_common_clinical_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/europepmc_scaling_chunk_002_common_clinical_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/pmc_oa_scaling_chunk_002_common_clinical_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "link_profiles",
      "label": "Link literature corpora through UMLS profile shards",
      "artifacts": [
        {
          "glob": "build/profile_evidence_scaling_chunk_002_common_clinical_materialized/*.jsonl",
          "kind": "jsonl",
          "min_files": 7,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "build_docs",
      "label": "Aggregate evidence into chunk-only CUI/view documents",
      "artifacts": [
        {
          "path": "build/scaling_chunk_002_common_clinical_concept_documents.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/scaling_chunk_002_common_clinical_docs.sqlite",
          "kind": "file"
        }
      ]
    },
    {
      "id": "embed_vectors",
      "label": "Embed chunk-only concept documents with SapBERT CLS vectors",
      "artifacts": [
        {
          "path": "build/scaling_chunk_002_common_clinical_concept_vectors.sapbert_cls.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "export_elastic",
      "label": "Export chunk-only vectors to Elasticsearch bulk files",
      "artifacts": [
        {
          "path": "build/qe-scaling-chunk-002-common-clinical-sapbert-cls.elastic.mapping.json",
          "kind": "file"
        },
        {
          "glob": "build/qe-scaling-chunk-002-common-clinical-sapbert-cls.elastic.bulk.part-*.ndjson",
          "kind": "jsonl",
          "min_files": 1,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "load_elastic",
      "label": "Load chunk-only vectors into Elasticsearch",
      "artifacts": [
        {
          "path": "build/scaling_runs/elasticsearch_loaded_chunk_002_sapbert_cls.marker",
          "kind": "file"
        }
      ]
    },
    {
      "id": "mimic_note_local_corpus",
      "label": "Parse local MIMIC-IV-Note discharge and radiology notes",
      "phase": "Restricted clinical data",
      "effort_weight": 2.0,
      "why": "Normalizes credentialed clinical notes into separate discharge and radiology corpora so clinical phrasing can be searched without mixing restricted source files into public literature corpora.",
      "artifacts": [
        {
          "path": "build/mimic_iv_note_local_pilot/mimic_iv_note_discharge_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 25000
        },
        {
          "path": "build/mimic_iv_note_local_pilot/mimic_iv_note_radiology_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 25000
        }
      ]
    },
    {
      "id": "mimic_note_local_link_profiles",
      "label": "Link MIMIC-IV-Note pilot text to UMLS CUIs",
      "phase": "Restricted clinical data",
      "effort_weight": 8.0,
      "why": "Turns note phrases into auditable CUI evidence rows, which is the real-world clinical evidence layer used before semantic search.",
      "artifacts": [
        {
          "glob": "build/profile_evidence_mimic_iv_note_local_pilot/*.jsonl",
          "kind": "jsonl",
          "min_files": 7,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "mimic_note_local_build_docs",
      "label": "Aggregate MIMIC-IV-Note evidence into CUI/view documents",
      "phase": "Restricted clinical data",
      "effort_weight": 3.0,
      "why": "Deduplicates millions of note-level mentions into compact CUI/view documents so retrieval ranks concepts rather than individual note snippets.",
      "artifacts": [
        {
          "path": "build/mimic_iv_note_local_pilot_concept_documents.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/mimic_iv_note_local_pilot_docs.sqlite",
          "kind": "file"
        }
      ]
    },
    {
      "id": "mimic_note_local_embed_vectors",
      "label": "Embed MIMIC-IV-Note CUI/view documents",
      "phase": "Restricted clinical data",
      "effort_weight": 5.0,
      "why": "Creates SapBERT vectors from clinical-note-backed concept documents so note evidence can participate in ANN search.",
      "artifacts": [
        {
          "path": "build/mimic_iv_note_local_pilot_concept_vectors.sapbert_cls.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "mimic_note_local_load_elastic",
      "label": "Load MIMIC-IV-Note pilot vectors into Elasticsearch",
      "phase": "Restricted clinical data",
      "effort_weight": 1.0,
      "why": "Adds the local clinical-note pilot to the same search alias as the literature indexes while preserving it as a separately measurable restricted source.",
      "artifacts": [
        {
          "path": "build/scaling_runs/elasticsearch_loaded_mimic_iv_note_local_pilot_sapbert_cls.marker",
          "kind": "file"
        }
      ]
    },
    {
      "id": "quality_review",
      "label": "Review search quality before merge",
      "artifacts": [
        {
          "path": "build/scaling_runs/scaling_chunk_002_common_clinical/search_quality_judgments.csv",
          "kind": "file"
        }
      ]
    }
  ]
}
