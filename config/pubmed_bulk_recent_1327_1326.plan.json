{
  "chunk_id": "pubmed_bulk_recent_1327_1326",
  "title": "PubMed bulk recent shards 1327 and 1326",
  "max_minutes_per_step": 10,
  "scope": "Fifth bounded PubMed bulk ingest pilot. Adds high-numbered 2026 baseline files pubmed26n1327 and pubmed26n1326 after the reviewed pubmed26n1329/pubmed26n1328 batch.",
  "steps": [
    {
      "id": "download_recent_1327_1326",
      "label": "Download PubMed 2026 baseline shards 1327 and 1326",
      "artifacts": [
        {
          "path": "data/pubmed/baseline/pubmed26n1327.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1327.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1326.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1326.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "build/pubmed_bulk_recent_1327_1326_manifest.json",
          "kind": "file"
        }
      ]
    },
    {
      "id": "parse_recent_1327_1326",
      "label": "Stream-parse shards 1327 and 1326 into corpus JSONL",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1327_1326_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "link_profiles",
      "label": "Link shards 1327 and 1326 through UMLS profile shards",
      "artifacts": [
        {
          "glob": "build/profile_evidence_pubmed_bulk_recent_1327_1326/*.jsonl",
          "kind": "jsonl",
          "min_files": 7,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "build_docs",
      "label": "Aggregate shards 1327 and 1326 evidence into CUI/view documents",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1327_1326_concept_documents.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/pubmed_bulk_recent_1327_1326_docs.sqlite",
          "kind": "file"
        }
      ]
    },
    {
      "id": "embed_vectors",
      "label": "Embed shards 1327 and 1326 CUI/view documents with SapBERT CLS vectors",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1327_1326_concept_vectors.sapbert_cls.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "export_load_elastic",
      "label": "Export and load shards 1327 and 1326 vectors into Elasticsearch",
      "artifacts": [
        {
          "path": "build/scaling_runs/elasticsearch_loaded_pubmed_bulk_recent_1327_1326_sapbert_cls.marker",
          "kind": "file"
        }
      ]
    },
    {
      "id": "quality_review",
      "label": "Review shards 1327 and 1326 search quality before wider bulk ingest",
      "artifacts": [
        {
          "path": "build/scaling_runs/pubmed_bulk_recent_1327_1326/search_quality_judgments.csv",
          "kind": "file"
        }
      ]
    }
  ]
}
