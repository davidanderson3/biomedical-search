{
  "chunk_id": "pubmed_bulk_recent_1325_1324",
  "title": "PubMed bulk recent shards 1325 and 1324",
  "max_minutes_per_step": 10,
  "scope": "Sixth bounded PubMed bulk ingest pilot. Adds high-numbered 2026 baseline files pubmed26n1325 and pubmed26n1324 after the ingested pubmed26n1327/pubmed26n1326 batch.",
  "steps": [
    {
      "id": "download_recent_1325_1324",
      "label": "Download PubMed 2026 baseline shards 1325 and 1324",
      "artifacts": [
        {
          "path": "data/pubmed/baseline/pubmed26n1325.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1325.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1324.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1324.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "build/pubmed_bulk_recent_1325_1324_manifest.json",
          "kind": "file"
        }
      ]
    },
    {
      "id": "parse_recent_1325_1324",
      "label": "Stream-parse shards 1325 and 1324 into corpus JSONL",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1325_1324_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "link_profiles",
      "label": "Link shards 1325 and 1324 through UMLS profile shards",
      "artifacts": [
        {
          "glob": "build/profile_evidence_pubmed_bulk_recent_1325_1324/*.jsonl",
          "kind": "jsonl",
          "min_files": 7,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "build_docs",
      "label": "Aggregate shards 1325 and 1324 evidence into CUI/view documents",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1325_1324_concept_documents.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/pubmed_bulk_recent_1325_1324_docs.sqlite",
          "kind": "file"
        }
      ]
    },
    {
      "id": "embed_vectors",
      "label": "Embed shards 1325 and 1324 CUI/view documents with SapBERT CLS vectors",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1325_1324_concept_vectors.sapbert_cls.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "export_load_elastic",
      "label": "Export and load shards 1325 and 1324 vectors into Elasticsearch",
      "artifacts": [
        {
          "path": "build/scaling_runs/elasticsearch_loaded_pubmed_bulk_recent_1325_1324_sapbert_cls.marker",
          "kind": "file"
        }
      ]
    },
    {
      "id": "quality_review",
      "label": "Review shards 1325 and 1324 search quality before wider bulk ingest",
      "artifacts": [
        {
          "path": "build/scaling_runs/pubmed_bulk_recent_1325_1324/search_quality_judgments.csv",
          "kind": "file"
        }
      ]
    }
  ]
}
