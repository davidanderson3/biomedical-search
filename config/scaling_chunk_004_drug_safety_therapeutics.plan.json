{
  "chunk_id": "scaling_chunk_004_drug_safety_therapeutics",
  "title": "Chunk 004: drug safety and therapeutics",
  "max_minutes_per_step": 10,
  "scope": "PubMed and Europe PMC only.",
  "steps": [
    {
      "id": "fetch_literature",
      "label": "Fetch PubMed and Europe PMC topic corpora",
      "artifacts": [
        {
          "path": "build/pubmed_scaling_chunk_004_drug_safety_therapeutics_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/europepmc_scaling_chunk_004_drug_safety_therapeutics_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "link_profiles",
      "label": "Link literature corpora through UMLS profile shards",
      "artifacts": [
        {
          "glob": "build/profile_evidence_scaling_chunk_004_drug_safety_therapeutics_materialized/*.jsonl",
          "kind": "jsonl",
          "min_files": 7,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "build_docs",
      "label": "Aggregate evidence into chunk-only CUI/view documents",
      "artifacts": [
        {
          "path": "build/scaling_chunk_004_drug_safety_therapeutics_concept_documents.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/scaling_chunk_004_drug_safety_therapeutics_docs.sqlite",
          "kind": "file"
        }
      ]
    },
    {
      "id": "embed_vectors",
      "label": "Embed chunk-only concept documents with SapBERT CLS vectors",
      "artifacts": [
        {
          "path": "build/scaling_chunk_004_drug_safety_therapeutics_concept_vectors.sapbert_cls.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "export_elastic",
      "label": "Export chunk-only vectors to Elasticsearch bulk files",
      "artifacts": [
        {
          "path": "build/qe-scaling-chunk-004-drug-safety-therapeutics-sapbert-cls.elastic.mapping.json",
          "kind": "file"
        },
        {
          "glob": "build/qe-scaling-chunk-004-drug-safety-therapeutics-sapbert-cls.elastic.bulk.part-*.ndjson",
          "kind": "jsonl",
          "min_files": 1,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "load_elastic",
      "label": "Load chunk-only vectors into Elasticsearch",
      "artifacts": [
        {
          "path": "build/scaling_runs/elasticsearch_loaded_chunk_004_sapbert_cls.marker",
          "kind": "file"
        }
      ]
    },
    {
      "id": "quality_review",
      "label": "Review search quality before merge",
      "artifacts": [
        {
          "path": "build/scaling_runs/scaling_chunk_004_drug_safety_therapeutics/search_quality_judgments.csv",
          "kind": "file"
        }
      ]
    }
  ]
}
