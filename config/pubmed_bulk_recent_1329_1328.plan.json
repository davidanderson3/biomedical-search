{
  "chunk_id": "pubmed_bulk_recent_1329_1328",
  "title": "PubMed bulk recent shards 1329 and 1328",
  "max_minutes_per_step": 10,
  "scope": "Fourth bounded PubMed bulk ingest pilot. Adds high-numbered 2026 baseline files pubmed26n1329 and pubmed26n1328 after the indexed provenance and compact-vector efficiency gate.",
  "steps": [
    {
      "id": "download_recent_1329_1328",
      "label": "Download PubMed 2026 baseline shards 1329 and 1328",
      "artifacts": [
        {
          "path": "data/pubmed/baseline/pubmed26n1329.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1329.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1328.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1328.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "build/pubmed_bulk_recent_1329_1328_manifest.json",
          "kind": "file"
        }
      ]
    },
    {
      "id": "parse_recent_1329_1328",
      "label": "Stream-parse shards 1329 and 1328 into corpus JSONL",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1329_1328_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "link_profiles",
      "label": "Link shards 1329 and 1328 through UMLS profile shards",
      "artifacts": [
        {
          "glob": "build/profile_evidence_pubmed_bulk_recent_1329_1328/*.jsonl",
          "kind": "jsonl",
          "min_files": 7,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "build_docs",
      "label": "Aggregate shards 1329 and 1328 evidence into CUI/view documents",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1329_1328_concept_documents.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/pubmed_bulk_recent_1329_1328_docs.sqlite",
          "kind": "file"
        }
      ]
    },
    {
      "id": "embed_vectors",
      "label": "Embed shards 1329 and 1328 CUI/view documents with SapBERT CLS vectors",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1329_1328_concept_vectors.sapbert_cls.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "export_load_elastic",
      "label": "Export and load shards 1329 and 1328 vectors into Elasticsearch",
      "artifacts": [
        {
          "path": "build/scaling_runs/elasticsearch_loaded_pubmed_bulk_recent_1329_1328_sapbert_cls.marker",
          "kind": "file"
        }
      ]
    },
    {
      "id": "quality_review",
      "label": "Review shards 1329 and 1328 search quality before wider bulk ingest",
      "artifacts": [
        {
          "path": "build/scaling_runs/pubmed_bulk_recent_1329_1328/search_quality_judgments.csv",
          "kind": "file"
        }
      ]
    }
  ]
}
