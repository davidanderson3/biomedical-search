{
  "chunk_id": "pubmed_bulk_recent_next2",
  "title": "PubMed bulk recent next-two-shards pilot",
  "max_minutes_per_step": 10,
  "scope": "Second PubMed bulk ingest pilot. Adds high-numbered 2026 baseline files pubmed26n1333 and pubmed26n1332 after the initial pubmed26n1334 pilot.",
  "steps": [
    {
      "id": "download_recent_next2",
      "label": "Download PubMed 2026 baseline shards 1333 and 1332",
      "artifacts": [
        {
          "path": "data/pubmed/baseline/pubmed26n1333.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1333.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1332.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1332.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "build/pubmed_bulk_recent_next2_manifest.json",
          "kind": "file"
        }
      ]
    },
    {
      "id": "parse_recent_next2",
      "label": "Stream-parse shards 1333 and 1332 into corpus JSONL",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_next2_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "link_profiles",
      "label": "Link next-two corpus through UMLS profile shards",
      "artifacts": [
        {
          "glob": "build/profile_evidence_pubmed_bulk_recent_next2/*.jsonl",
          "kind": "jsonl",
          "min_files": 7,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "build_docs",
      "label": "Aggregate next-two evidence into CUI/view documents",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_next2_concept_documents.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/pubmed_bulk_recent_next2_docs.sqlite",
          "kind": "file"
        }
      ]
    },
    {
      "id": "embed_vectors",
      "label": "Embed next-two CUI/view documents with SapBERT CLS vectors",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_next2_concept_vectors.sapbert_cls.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "export_load_elastic",
      "label": "Export and load next-two vectors into Elasticsearch",
      "artifacts": [
        {
          "path": "build/scaling_runs/elasticsearch_loaded_pubmed_bulk_recent_next2_sapbert_cls.marker",
          "kind": "file"
        }
      ]
    },
    {
      "id": "quality_review",
      "label": "Review next-two search quality before wider bulk ingest",
      "artifacts": [
        {
          "path": "build/scaling_runs/pubmed_bulk_recent_next2/search_quality_judgments.csv",
          "kind": "file"
        }
      ]
    }
  ]
}
