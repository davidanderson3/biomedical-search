{
  "chunk_id": "pubmed_bulk_recent_1323_1322",
  "title": "PubMed bulk recent shards 1323 and 1322",
  "max_minutes_per_step": 10,
  "scope": "Seventh bounded PubMed bulk ingest pilot. Adds high-numbered 2026 baseline files pubmed26n1323 and pubmed26n1322 after the ingested pubmed26n1325/pubmed26n1324 batch.",
  "steps": [
    {
      "id": "download_recent_1323_1322",
      "label": "Download PubMed 2026 baseline shards 1323 and 1322",
      "artifacts": [
        {
          "path": "data/pubmed/baseline/pubmed26n1323.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1323.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1322.xml.gz",
          "kind": "file"
        },
        {
          "path": "data/pubmed/baseline/pubmed26n1322.xml.gz.md5",
          "kind": "file"
        },
        {
          "path": "build/pubmed_bulk_recent_1323_1322_manifest.json",
          "kind": "file"
        }
      ]
    },
    {
      "id": "parse_recent_1323_1322",
      "label": "Stream-parse shards 1323 and 1322 into corpus JSONL",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1323_1322_corpus.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "link_profiles",
      "label": "Link shards 1323 and 1322 through UMLS profile shards",
      "artifacts": [
        {
          "glob": "build/profile_evidence_pubmed_bulk_recent_1323_1322/*.jsonl",
          "kind": "jsonl",
          "min_files": 7,
          "min_rows": 1
        }
      ]
    },
    {
      "id": "build_docs",
      "label": "Aggregate shards 1323 and 1322 evidence into CUI/view documents",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1323_1322_concept_documents.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        },
        {
          "path": "build/pubmed_bulk_recent_1323_1322_docs.sqlite",
          "kind": "file"
        }
      ]
    },
    {
      "id": "embed_vectors",
      "label": "Embed shards 1323 and 1322 CUI/view documents with SapBERT CLS vectors",
      "artifacts": [
        {
          "path": "build/pubmed_bulk_recent_1323_1322_concept_vectors.sapbert_cls.jsonl",
          "kind": "jsonl",
          "min_rows": 1
        }
      ]
    },
    {
      "id": "export_load_elastic",
      "label": "Export and load shards 1323 and 1322 vectors into Elasticsearch",
      "artifacts": [
        {
          "path": "build/scaling_runs/elasticsearch_loaded_pubmed_bulk_recent_1323_1322_sapbert_cls.marker",
          "kind": "file"
        }
      ]
    },
    {
      "id": "quality_review",
      "label": "Review shards 1323 and 1322 search quality before wider bulk ingest",
      "artifacts": [
        {
          "path": "build/scaling_runs/pubmed_bulk_recent_1323_1322/search_quality_judgments.csv",
          "kind": "file"
        }
      ]
    }
  ]
}
